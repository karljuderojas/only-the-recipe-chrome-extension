# Copy this file to `keystore.properties` (same directory) and fill in your
# real values. The real file is gitignored — never commit it.
#
# Generate the keystore once with:
#   keytool -genkeypair -v -keystore <path>.jks -storetype JKS -keyalg RSA \
#           -keysize 2048 -validity 10000 -alias upload
#
# Lose this file or its password and you can never update the Play listing.

storeFile=C:/Users/karlj/keystores/only-the-recipe-upload.jks
storePassword=replace-me
keyAlias=upload
keyPassword=replace-me
