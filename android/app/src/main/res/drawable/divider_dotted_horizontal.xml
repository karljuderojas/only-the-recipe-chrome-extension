<?xml version="1.0" encoding="utf-8"?>
<!-- Dotted divider used between ingredient rows. Consumer Views must be 1dp
     tall and use android:layerType="software" because Android's DashPathEffect
     does not render under hardware acceleration. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent"/>
    <stroke
        android:width="1dp"
        android:color="@color/otr_rule"
        android:dashWidth="2dp"
        android:dashGap="2dp"/>
</shape>
