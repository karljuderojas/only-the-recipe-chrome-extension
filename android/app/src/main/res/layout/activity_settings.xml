<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/otr_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:requiresFadingEdge="none"
            android:fadingEdgeLength="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ─── Header block ─── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="@dimen/otr_space_24">

                    <LinearLayout
                        android:id="@+id/settingsBackBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/otr_space_8"
                        android:paddingTop="@dimen/otr_space_4"
                        android:paddingBottom="@dimen/otr_space_4"
                        android:paddingEnd="@dimen/otr_space_8"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_otr_back"
                            app:tint="@color/otr_muted"
                            android:contentDescription="@null"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Back"
                            android:textAppearance="@style/TextAppearance.OTR.MonoCaption"
                            android:layout_marginStart="@dimen/otr_space_6"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Settings."
                        android:textAppearance="@style/TextAppearance.OTR.Display"/>

                    <TextView
                        android:layout_width="240dp"
                        android:layout_height="wrap_content"
                        android:text="Everything is stored on this device."
                        android:textAppearance="@style/TextAppearance.OTR.BodySmall"
                        android:layout_marginTop="@dimen/otr_space_10"
                        android:layout_marginBottom="@dimen/otr_space_18"/>
                </LinearLayout>

                <!-- ─── PREFERENCES section ─── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Preferences"
                    android:textAppearance="@style/TextAppearance.OTR.MonoCaption"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="@dimen/otr_space_10"
                    android:paddingBottom="@dimen/otr_space_4"/>

                <!-- Row: Use metric units -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="@dimen/otr_space_14"
                    android:paddingBottom="@dimen/otr_space_14"
                    android:background="@color/otr_bg">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Use metric units"
                            android:textAppearance="@style/TextAppearance.OTR.SettingsRowLabel"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Convert measurements as recipes are rendered"
                            android:fontFamily="@font/manrope"
                            android:textSize="11sp"
                            android:textColor="@color/otr_muted"
                            android:layout_marginTop="@dimen/otr_space_2"/>
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/metricSwitch"
                        android:layout_width="36dp"
                        android:layout_height="20dp"
                        app:track="@drawable/toggle_track"
                        android:thumb="@drawable/toggle_thumb"
                        android:padding="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:layout_marginStart="@dimen/otr_space_14"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/otr_rule_hairline"
                    android:background="@color/otr_rule"/>

                <!-- Row: Default servings -->
                <LinearLayout
                    android:id="@+id/servingsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="@dimen/otr_space_14"
                    android:paddingBottom="@dimen/otr_space_14"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Default servings"
                            android:textAppearance="@style/TextAppearance.OTR.SettingsRowLabel"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scaling applied to ingredient quantities"
                            android:fontFamily="@font/manrope"
                            android:textSize="11sp"
                            android:textColor="@color/otr_muted"
                            android:layout_marginTop="@dimen/otr_space_2"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/servingsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.OTR.MonoButton"
                        android:layout_marginStart="@dimen/otr_space_14"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/otr_rule_hairline"
                    android:background="@color/otr_rule"/>

                <!-- Row: Show cook's notes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="@dimen/otr_space_14"
                    android:paddingBottom="@dimen/otr_space_14">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show cook's notes"
                            android:textAppearance="@style/TextAppearance.OTR.SettingsRowLabel"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Author tips at the end of each recipe"
                            android:fontFamily="@font/manrope"
                            android:textSize="11sp"
                            android:textColor="@color/otr_muted"
                            android:layout_marginTop="@dimen/otr_space_2"/>
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/showNotesSwitch"
                        android:layout_width="36dp"
                        android:layout_height="20dp"
                        app:track="@drawable/toggle_track"
                        android:thumb="@drawable/toggle_thumb"
                        android:padding="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:layout_marginStart="@dimen/otr_space_14"/>
                </LinearLayout>

                <!-- ─── DATA section ─── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data"
                    android:textAppearance="@style/TextAppearance.OTR.MonoCaption"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="@dimen/otr_space_22"
                    android:paddingBottom="@dimen/otr_space_4"/>

                <!-- Row: Export library -->
                <LinearLayout
                    android:id="@+id/exportRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="@dimen/otr_space_14"
                    android:paddingBottom="@dimen/otr_space_14"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Export library"
                            android:textAppearance="@style/TextAppearance.OTR.SettingsRowLabel"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Save all recipes as a .json file"
                            android:fontFamily="@font/manrope"
                            android:textSize="11sp"
                            android:textColor="@color/otr_muted"
                            android:layout_marginTop="@dimen/otr_space_2"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Export →"
                        android:textAppearance="@style/TextAppearance.OTR.MonoButton"
                        android:layout_marginStart="@dimen/otr_space_14"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/otr_rule_hairline"
                    android:background="@color/otr_rule"/>

                <!-- Row: Clear grocery list -->
                <LinearLayout
                    android:id="@+id/clearGroceryRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="@dimen/otr_space_14"
                    android:paddingBottom="@dimen/otr_space_14"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clear grocery list"
                            android:textAppearance="@style/TextAppearance.OTR.SettingsRowLabel"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Removes every item"
                            android:fontFamily="@font/manrope"
                            android:textSize="11sp"
                            android:textColor="@color/otr_muted"
                            android:layout_marginTop="@dimen/otr_space_2"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear →"
                        android:textAppearance="@style/TextAppearance.OTR.MonoButton"
                        android:layout_marginStart="@dimen/otr_space_14"/>
                </LinearLayout>

                <!-- ─── ABOUT section ─── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About"
                    android:textAppearance="@style/TextAppearance.OTR.MonoCaption"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="@dimen/otr_space_22"
                    android:paddingBottom="@dimen/otr_space_4"/>

                <!-- Row: Privacy Policy -->
                <LinearLayout
                    android:id="@+id/privacyRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="@dimen/otr_space_14"
                    android:paddingBottom="@dimen/otr_space_14"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Privacy policy"
                            android:textAppearance="@style/TextAppearance.OTR.SettingsRowLabel"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="What we store and don't store"
                            android:fontFamily="@font/manrope"
                            android:textSize="11sp"
                            android:textColor="@color/otr_muted"
                            android:layout_marginTop="@dimen/otr_space_2"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Open →"
                        android:textAppearance="@style/TextAppearance.OTR.MonoButton"
                        android:layout_marginStart="@dimen/otr_space_14"/>
                </LinearLayout>

                <!-- Version footer -->
                <TextView
                    android:id="@+id/versionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.OTR.MonoCaption"
                    android:paddingStart="@dimen/otr_space_22"
                    android:paddingEnd="@dimen/otr_space_22"
                    android:paddingTop="36dp"
                    android:paddingBottom="@dimen/otr_space_22"/>
            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/otr_rule_hairline"
            android:background="@color/otr_rule"/>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:menu="@menu/bottom_nav_menu"/>
    </LinearLayout>
</FrameLayout>
