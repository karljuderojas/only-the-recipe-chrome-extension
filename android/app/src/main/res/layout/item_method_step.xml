<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="@dimen/otr_space_12"
    android:requiresFadingEdge="none"
    android:fadingEdgeLength="0dp">

    <TextView
        android:id="@+id/stepNumber"
        android:layout_width="22dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.OTR.MethodNumeral"/>

    <TextView
        android:id="@+id/stepBody"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.OTR.Body"
        android:lineSpacingExtra="7sp"
        android:includeFontPadding="true"
        android:requiresFadingEdge="none"
        android:fadingEdgeLength="0dp"
        android:paddingBottom="14dp"
        android:layout_marginStart="@dimen/otr_space_14"/>
</LinearLayout>
