<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/otr_bg">

    <!-- Toolbar: CANCEL (muted) ← → SAVE (accent) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/otr_space_18"
        android:paddingEnd="@dimen/otr_space_18"
        android:paddingTop="@dimen/otr_space_14"
        android:paddingBottom="@dimen/otr_space_6">

        <TextView
            android:id="@+id/editCancelBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textAppearance="@style/TextAppearance.OTR.MonoButtonMuted"
            android:paddingTop="@dimen/otr_space_4"
            android:paddingBottom="@dimen/otr_space_4"
            android:paddingEnd="@dimen/otr_space_8"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/editSaveBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textAppearance="@style/TextAppearance.OTR.MonoButton"
            android:paddingTop="@dimen/otr_space_4"
            android:paddingBottom="@dimen/otr_space_4"
            android:paddingStart="@dimen/otr_space_8"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:requiresFadingEdge="none"
        android:fadingEdgeLength="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/otr_space_24">

            <!-- Header block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/otr_space_22"
                android:paddingEnd="@dimen/otr_space_22"
                android:paddingTop="@dimen/otr_space_8">

                <TextView
                    android:id="@+id/editKicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.OTR.MonoCaption"
                    android:layout_marginBottom="@dimen/otr_space_4"/>

                <TextView
                    android:id="@+id/editTitleDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.OTR.Display"/>

                <TextView
                    android:id="@+id/editTagline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.OTR.BodySmall"
                    android:layout_marginTop="@dimen/otr_space_10"
                    android:layout_marginBottom="@dimen/otr_space_18"/>
            </LinearLayout>

            <!-- Title section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/otr_space_22"
                android:paddingEnd="@dimen/otr_space_22"
                android:paddingTop="@dimen/otr_space_8"
                android:paddingBottom="@dimen/otr_space_18">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/otr_space_10">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Title"
                        android:textAppearance="@style/TextAppearance.OTR.SectionLabel"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="@dimen/otr_rule_hairline"
                        android:background="@color/otr_rule"
                        android:layout_marginStart="@dimen/otr_space_10"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/editTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond"
                    android:textSize="19sp"
                    android:textColor="@color/otr_ink"
                    android:textColorHint="@color/otr_muted"
                    android:hint="Recipe title"
                    android:inputType="textCapSentences"
                    android:singleLine="true"
                    android:includeFontPadding="true"
                    android:background="@drawable/bg_notes_card"
                    android:padding="@dimen/otr_space_12"/>
            </LinearLayout>

            <!-- Ingredients section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/otr_space_22"
                android:paddingEnd="@dimen/otr_space_22"
                android:paddingTop="@dimen/otr_space_4"
                android:paddingBottom="@dimen/otr_space_18">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/otr_space_6">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ingredients"
                        android:textAppearance="@style/TextAppearance.OTR.SectionLabel"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="@dimen/otr_rule_hairline"
                        android:background="@color/otr_rule"
                        android:layout_marginStart="@dimen/otr_space_10"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="One per line."
                    android:textAppearance="@style/TextAppearance.OTR.BodySmall"
                    android:layout_marginBottom="@dimen/otr_space_8"/>

                <EditText
                    android:id="@+id/editIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.OTR.Body"
                    android:textColorHint="@color/otr_muted"
                    android:hint="3 cups bread flour\n1 cup lukewarm water\n…"
                    android:inputType="textMultiLine|textCapSentences"
                    android:gravity="top"
                    android:minLines="5"
                    android:background="@drawable/bg_notes_card"
                    android:padding="@dimen/otr_space_12"
                    android:includeFontPadding="true"/>
            </LinearLayout>

            <!-- Method section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/otr_space_22"
                android:paddingEnd="@dimen/otr_space_22"
                android:paddingTop="@dimen/otr_space_4"
                android:paddingBottom="@dimen/otr_space_24">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/otr_space_6">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Method"
                        android:textAppearance="@style/TextAppearance.OTR.SectionLabel"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="@dimen/otr_rule_hairline"
                        android:background="@color/otr_rule"
                        android:layout_marginStart="@dimen/otr_space_10"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="One step per line. Prefix a line with “§:” to start a section (e.g. §:For the sauce)."
                    android:textAppearance="@style/TextAppearance.OTR.BodySmall"
                    android:layout_marginBottom="@dimen/otr_space_8"/>

                <EditText
                    android:id="@+id/editInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.OTR.Body"
                    android:textColorHint="@color/otr_muted"
                    android:hint="Mix the dry ingredients.\nAdd the wet ingredients.\n…"
                    android:inputType="textMultiLine|textCapSentences"
                    android:gravity="top"
                    android:minLines="7"
                    android:background="@drawable/bg_notes_card"
                    android:padding="@dimen/otr_space_12"
                    android:includeFontPadding="true"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
