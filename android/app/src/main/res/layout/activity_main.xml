<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/otr_bg">

    <!-- ─── Library tab ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/libraryContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Editorial header: caption + gear, display title, tagline, URL input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/otr_space_22"
            android:paddingEnd="@dimen/otr_space_22"
            android:paddingTop="@dimen/otr_space_24">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="@dimen/otr_space_4">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="No. 01 — Library"
                    android:textAppearance="@style/TextAppearance.OTR.MonoCaption"/>

                <ImageButton
                    android:id="@+id/settingsBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_otr_settings"
                    app:tint="@color/otr_muted"
                    android:scaleType="centerInside"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Settings"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Only the\nrecipe."
                android:textAppearance="@style/TextAppearance.OTR.Display"/>

            <TextView
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:text="A quiet shelf of recipes you actually use — nothing more."
                android:textAppearance="@style/TextAppearance.OTR.BodySmall"
                android:layout_marginTop="@dimen/otr_space_12"
                android:layout_marginBottom="@dimen/otr_space_18"/>

            <!-- URL input row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_url_input"
                android:paddingStart="@dimen/otr_space_12"
                android:paddingEnd="@dimen/otr_space_12"
                android:paddingTop="@dimen/otr_space_10"
                android:paddingBottom="@dimen/otr_space_10">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_otr_paste"
                    app:tint="@color/otr_muted"
                    android:layout_marginEnd="@dimen/otr_space_10"
                    android:contentDescription="@null"/>

                <EditText
                    android:id="@+id/urlInput"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="paste a recipe url"
                    android:fontFamily="@font/jetbrains_mono"
                    android:textSize="12sp"
                    android:textColor="@color/otr_ink"
                    android:textColorHint="@color/otr_muted"
                    android:background="@null"
                    android:inputType="textUri"
                    android:imeOptions="actionGo"
                    android:singleLine="true"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:padding="0dp"/>

                <TextView
                    android:id="@+id/goBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Get →"
                    android:textAppearance="@style/TextAppearance.OTR.MonoButton"
                    android:paddingStart="@dimen/otr_space_10"
                    android:paddingTop="@dimen/otr_space_4"
                    android:paddingBottom="@dimen/otr_space_4"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- "Saved" section header — visible only when the list has rows -->
        <LinearLayout
            android:id="@+id/savedHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/otr_space_22"
            android:paddingEnd="@dimen/otr_space_22"
            android:paddingTop="@dimen/otr_space_26"
            android:paddingBottom="@dimen/otr_space_10">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saved"
                android:textAppearance="@style/TextAppearance.OTR.SectionLabel"/>

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="1dp"
                android:background="@color/otr_rule"
                android:layout_marginStart="@dimen/otr_space_12"
                android:layout_marginEnd="@dimen/otr_space_12"/>

            <TextView
                android:id="@+id/savedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.OTR.MonoNumber"
                android:text="0"/>
        </LinearLayout>

        <!-- Recipe list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recipeList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/otr_space_16"/>

        <!-- Empty state — replaces savedHeader + recipeList when no recipes saved -->
        <LinearLayout
            android:id="@+id/emptyView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:paddingTop="60dp"
            android:paddingBottom="60dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/shape_dashed_circle"
                android:layerType="software"
                android:layout_marginBottom="@dimen/otr_space_18">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_otr_book"
                    app:tint="@color/otr_muted"
                    android:contentDescription="@null"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your shelf is bare."
                android:textAppearance="@style/TextAppearance.OTR.Heading"/>

            <TextView
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="Paste a link above, or share a recipe from your browser. We'll keep just the parts you actually need."
                android:textAppearance="@style/TextAppearance.OTR.BodySmall"
                android:gravity="center"
                android:layout_marginTop="@dimen/otr_space_10"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ─── Grocery tab ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/groceryContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Editorial header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/otr_space_22"
            android:paddingEnd="@dimen/otr_space_22"
            android:paddingTop="@dimen/otr_space_24">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No. 02 — Market"
                android:textAppearance="@style/TextAppearance.OTR.MonoCaption"
                android:layout_marginBottom="@dimen/otr_space_4"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grocery\nlist."
                android:textAppearance="@style/TextAppearance.OTR.Display"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/otr_space_14"
                android:layout_marginBottom="@dimen/otr_space_18">

                <TextView
                    android:id="@+id/groceryToBuyCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.OTR.MonoCaption"
                    android:textColor="@color/otr_accent"/>

                <View
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="@dimen/otr_rule_hairline"
                    android:background="@color/otr_rule"
                    android:layout_marginStart="@dimen/otr_space_10"
                    android:layout_marginEnd="@dimen/otr_space_10"/>

                <TextView
                    android:id="@+id/clearDoneBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear done"
                    android:textAppearance="@style/TextAppearance.OTR.MonoCaption"
                    android:paddingTop="@dimen/otr_space_4"
                    android:paddingBottom="@dimen/otr_space_4"
                    android:paddingStart="@dimen/otr_space_4"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/groceryEmptyView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nothing on the list."
                android:textAppearance="@style/TextAppearance.OTR.Heading"/>

            <TextView
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="Open a recipe and tap “+ List” to add its ingredients here."
                android:textAppearance="@style/TextAppearance.OTR.BodySmall"
                android:gravity="center"
                android:layout_marginTop="@dimen/otr_space_10"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/groceryList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/otr_space_16"/>
    </LinearLayout>

    <!-- Top border for the bottom nav (1dp rule) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/otr_rule_hairline"
        android:background="@color/otr_rule"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>
