{
  "manifest_version": 3,
  "name": "Only The Recipe",
  "version": "1.0.0",
  "description": "Strips SEO noise from recipe pages so you see only the recipe — and saves them to a personal local library.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/extractor.js",
        "content/isolator.js",
        "content/browser.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["cache/cache.html", "cache/cache.js", "storage/storage.js", "onboarding/welcome.html", "plugins/plugin.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
